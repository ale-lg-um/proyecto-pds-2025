<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>


<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" spacing="30.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.um.pds.tarjetas.ui.controllers.DashboardController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Selecciona un tablero:" />
            <ListView fx:id="listaTableros" prefHeight="200.0" prefWidth="200.0" style="-fx-font-size: 14px;" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" spacing="20.0">
         <children>
            <Button fx:id="btnCrear" mnemonicParsing="false" onAction="#accionCrearTablero" prefHeight="40.0" prefWidth="200.0" text="Crear tablero" />
            <Button fx:id="btnUnirsePorUrl" mnemonicParsing="false" onAction="#accionUnirsePorUrl" prefHeight="40.0" prefWidth="200.0" text="Unirse por URL" />
            <Button fx:id="btnEntrar" mnemonicParsing="false" onAction="#accionEntrarTablero" prefHeight="40.0" prefWidth="200.0" text="Entrar al tablero" />
            <Button fx:id="btnBorrar" mnemonicParsing="false" onAction="#accionBorrarTableros" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: red; -fx-text-fill: white; -fx-font-weight: bold;" text="Borrar tableros" />
         </children>
      </VBox>
   </children>
</HBox>
